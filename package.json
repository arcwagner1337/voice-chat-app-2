{
  "name": "voice-chat-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "test_mic": "ffplay -nodisp -f s16le -ar 44100 -ch_layout mono -probesize 32 -i udp://0.0.0.0:5000",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "npx expo prebuild",
    "build:android": "npx expo run:android",
    "build:ios": "npx expo run:ios",
    "ghbuild:a": "gh workflow run 'Build Mobile (Manual)' -f platform=android -f profile=development"
  },
  "dependencies": {
    "@config-plugins/react-native-webrtc": "13.0.0",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^7.1.6",
    "@voximplant/react-native-foreground-service": "^3.0.2",
    "buffer": "^6.0.3",
    "expo": "^54.0.34",
    "expo-av": "~16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-linking": "~8.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.7",
    "expo-web-browser": "~15.0.7",
    "express": "^5.2.1",
    "nativewind": "latest",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-background-actions": "^4.1.0",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-incall-manager": "^4.2.1",
    "react-native-live-audio-stream": "^1.1.1",
    "react-native-network-info": "^5.2.2",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-tcp-socket": "^6.4.1",
    "react-native-udp": "^4.1.7",
    "react-native-web": "^0.21.0",
    "react-native-webrtc": "^124.0.7",
    "react-native-worklets": "0.5.1",
    "react-native-zeroconf": "^0.14.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~19.1.10",
    "@types/react-native-zeroconf": "^0.13.1",
    "eslint": "^9.25.1",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.2",
    "prettier": "^3.2.5",
    "prettier-plugin-tailwindcss": "^0.5.11",
    "tailwindcss": "^3.4.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false,
        "exclude": [
          "react-native-incall-manager",
          "react-native-webrtc",
          "react-native-udp",
          "react-native-tcp-socket",
          "react-native-background-actions",
          "react-native-network-info",
          "@voximplant/react-native-foreground-service",
          "react-native-live-audio-stream"
        ]
      }
    }
  }
}